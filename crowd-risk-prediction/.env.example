# Crowd Risk Analysis - Environment Configuration
# Copy this file to .env and update with your settings

# Redis Configuration
REDIS_PASSWORD=crowdrisk2026
REDIS_URL=redis://redis:6379

# Grafana Configuration
GRAFANA_PASSWORD=admin

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# GPU Configuration
NVIDIA_VISIBLE_DEVICES=all
CUDA_VISIBLE_DEVICES=0

# Emergency Alerts
ENABLE_EMERGENCY_ALERTS=true
ALERT_COOLDOWN=300  # seconds between similar alerts

# SMTP Configuration (for email alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=alerts@crowd-risk.com

# External API Keys (optional)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# Model Configuration
MODEL_PATH=models/ciri_model_best.pth
USE_GPU=true
BATCH_SIZE=16

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
